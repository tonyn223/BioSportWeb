@model BioSportWeb.Models.Planes

@{
    ViewData["Title"] = "Editar Plan";
}

<div class="container mt-4">
    <h2 class="text-primary">Editar Plan</h2>
    <hr />
    <div class="row">
        <div class="col-md-5">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <input type="hidden" asp-for="IdPlan" />
                
                <div class="form-group mb-3">
                    <label asp-for="Nombre" class="control-label fw-bold"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Precio" class="control-label fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text">₡</span>
                        <input asp-for="Precio" type="number" step="0.01" class="form-control" />
                    </div>
                    <span asp-validation-for="Precio" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-4">
                    <label asp-for="DuracionDias" class="control-label fw-bold">Duración (Días)</label>
                    <input asp-for="DuracionDias" type="number" class="form-control" />
                    <span asp-validation-for="DuracionDias" class="text-danger"></span>
                </div>
                
                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Guardar Cambios
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}